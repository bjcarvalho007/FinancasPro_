rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default to deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validator definitions
    function isValidUser(data) {
      return (!data.keys().hasAny(['uid']) || data.uid == request.auth.uid)
        && data.email is string && data.email.size() <= 200
        && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 150))
        && (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 1000));
    }

    function isValidRegistration(data) {
      return data.userId == request.auth.uid
        && data.email is string && data.email.size() <= 200
        && (!data.keys().hasAny(['claimedAt']) || (data.claimedAt is string && data.claimedAt.size() <= 100));
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.amount is number && data.amount >= 0 && data.amount <= 100000000
        && (data.type == 'fixos' || data.type == 'variaveis' || data.type == 'parcelas')
        && data.cat is string && data.cat.size() <= 50
        && data.monthKey is string && data.monthKey.size() == 7
        && data.paid_amount is number && data.paid_amount >= 0
        && (!data.keys().hasAny(['due']) || (data.due is string && data.due.size() <= 50))
        && (!data.keys().hasAny(['paid_at']) || (data.paid_at is string && data.paid_at.size() <= 50))
        && (!data.keys().hasAny(['masterId']) || (data.masterId is string && data.masterId.size() <= 128))
        && (!data.keys().hasAny(['extra_gasto']) || (data.extra_gasto is number))
        && (!data.keys().hasAny(['keep_showing']) || (data.keep_showing is bool))
        && (!data.keys().hasAny(['extension_months']) || (data.extension_months is number))
        && (!data.keys().hasAny(['target_payoff_month']) || (data.target_payoff_month is string && data.target_payoff_month.size() <= 10))
        && (!data.keys().hasAny(['target_payoff_date']) || (data.target_payoff_date is string && data.target_payoff_date.size() <= 15))
        && (!data.keys().hasAny(['createdAt']) || (data.createdAt is string && data.createdAt.size() <= 100))
        && (!data.keys().hasAny(['updatedAt']) || (data.updatedAt is string && data.updatedAt.size() <= 100));
    }

    function isValidCategory(data) {
      return data.userId == request.auth.uid
        && data.id is string && data.id.size() <= 128
        && data.icon is string && data.icon.size() <= 20
        && data.label is string && data.label.size() <= 100
        && data.value is string && data.value.size() <= 100;
    }

    function isValidGoal(data) {
      return data.userId == request.auth.uid
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 150
        && data.targetAmount is number && data.targetAmount >= 0
        && data.currentAmount is number && data.currentAmount >= 0
        && (!data.keys().hasAny(['deadline']) || (data.deadline is string && data.deadline.size() <= 50))
        && (!data.keys().hasAny(['createdAt']) || (data.createdAt is string && data.createdAt.size() <= 50));
    }

    function isValidSetting(data) {
      return data.userId == request.auth.uid
        && data.currency is string && (data.currency == 'BRL' || data.currency == 'USD' || data.currency == 'EUR')
        && data.theme is string && (data.theme == 'dark' || data.theme == 'light')
        && data.income is number && data.income >= 0
        && data.balance is number && data.balance >= 0
        && (!data.keys().hasAny(['extras']) || data.extras is map)
        && (!data.keys().hasAny(['monthlyIncome']) || data.monthlyIncome is map)
        && (!data.keys().hasAny(['monthlyBalance']) || data.monthlyBalance is map)
        && (!data.keys().hasAny(['extraEarnings']) || data.extraEarnings is list);
    }

    function isValidNotification(data) {
      return data.userId == request.auth.uid
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.body is string && data.body.size() <= 1000
        && data.read is bool;
    }

    function isValidTokenPago(data) {
      return data.token is string && data.token.size() <= 128
        && data.email is string && data.email.size() <= 200
        && data.used is bool
        && (!data.keys().hasAny(['userId']) || (data.userId is string && data.userId.size() <= 128))
        && (!data.keys().hasAny(['usedAt']) || (data.usedAt is string && data.usedAt.size() <= 100))
        && (!data.keys().hasAny(['createdAt']) || (data.createdAt is string && data.createdAt.size() <= 100));
    }

    function isValidBusinessProfile(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.description is string && data.description.size() <= 1000
        && data.workingDays is list && data.workingDays.size() <= 7
        && data.workingHoursStart is string && data.workingHoursStart.size() <= 5
        && data.workingHoursEnd is string && data.workingHoursEnd.size() <= 5
        && data.active is bool
        && (!data.keys().hasAny(['address']) || (data.address is string && data.address.size() <= 300))
        && (!data.keys().hasAny(['phone']) || (data.phone is string && data.phone.size() <= 50))
        && (!data.keys().hasAny(['lunchStart']) || (data.lunchStart is string && data.lunchStart.size() <= 5))
        && (!data.keys().hasAny(['lunchEnd']) || (data.lunchEnd is string && data.lunchEnd.size() <= 5))
        && (!data.keys().hasAny(['createdAt']) || (data.createdAt is string && data.createdAt.size() <= 100))
        && (!data.keys().hasAny(['updatedAt']) || (data.updatedAt is string && data.updatedAt.size() <= 100));
    }

    function isValidBusinessService(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.price is number && data.price >= 0
        && data.duration is number && data.duration > 0
        && data.active is bool
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 1000))
        && (!data.keys().hasAny(['createdAt']) || (data.createdAt is string && data.createdAt.size() <= 100));
    }

    function isValidBusinessBooking(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.id is string && data.id.size() <= 128
        && data.clientName is string && data.clientName.size() > 0 && data.clientName.size() <= 150
        && data.clientEmail is string && data.clientEmail.size() > 0 && data.clientEmail.size() <= 200
        && data.clientPhone is string && data.clientPhone.size() > 0 && data.clientPhone.size() <= 50
        && data.serviceId is string && data.serviceId.size() <= 128
        && data.serviceName is string && data.serviceName.size() <= 150
        && data.servicePrice is number && data.servicePrice >= 0
        && data.serviceDuration is number && data.serviceDuration > 0
        && data.date is string && data.date.size() <= 15
        && data.time is string && data.time.size() <= 5
        && (data.status == 'pending' || data.status == 'accepted' || data.status == 'rejected' || data.status == 'completed' || data.status == 'cancelled')
        && (!data.keys().hasAny(['notes']) || (data.notes is string && data.notes.size() <= 1000))
        && (!data.keys().hasAny(['createdAt']) || (data.createdAt is string && data.createdAt.size() <= 100))
        && (!data.keys().hasAny(['updatedAt']) || (data.updatedAt is string && data.updatedAt.size() <= 100));
    }

    // Rules for Collections
    match /users/{userId} {
      allow get: if isOwner(userId) || (request.auth.token.email == 'bjcarvalho07@gmail.com' && request.auth.token.email_verified == true);
      allow list: if request.auth.token.email == 'bjcarvalho07@gmail.com' && request.auth.token.email_verified == true;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if request.auth.token.email == 'bjcarvalho07@gmail.com' && request.auth.token.email_verified == true;
      allow delete: if request.auth.token.email == 'bjcarvalho07@gmail.com' && request.auth.token.email_verified == true;
    }

    match /transactions/{transactionId} {
      allow get, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(transactionId) && isValidTransaction(incoming());
      allow update: if isSignedIn() && isValidId(transactionId) && existing().userId == request.auth.uid && isValidTransaction(incoming()) && incoming().userId == existing().userId;
    }

    match /categories/{categoryId} {
      allow get, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isSignedIn() && isValidId(categoryId) && existing().userId == request.auth.uid && isValidCategory(incoming()) && incoming().userId == existing().userId;
    }

    match /goals/{goalId} {
      allow get, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(goalId) && isValidGoal(incoming());
      allow update: if isSignedIn() && isValidId(goalId) && existing().userId == request.auth.uid && isValidGoal(incoming()) && incoming().userId == existing().userId;
    }

    match /settings/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSetting(incoming());
      allow update: if isOwner(userId) && isValidSetting(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }

    match /notifications/{notificationId} {
      allow get, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming());
      allow update: if isSignedIn() && isValidId(notificationId) && existing().userId == request.auth.uid && isValidNotification(incoming()) && incoming().userId == existing().userId;
    }

    match /push_subscriptions/{subId} {
      allow get, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(subId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(subId) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
    }

    match /registrations/{registrationId} {
      allow get: if true;
      allow create: if isSignedIn() && isValidId(registrationId) && isValidRegistration(incoming());
      allow update: if isSignedIn() && isValidId(registrationId) && existing().userId == request.auth.uid && isValidRegistration(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isValidId(registrationId) && existing().userId == request.auth.uid;
    }

    match /tokens_pagos/{tokenId} {
      allow get: if true;
      allow create: if false; // Only server (firebase-admin) can create tokens
      allow update: if isSignedIn()
        && existing().used == false
        && incoming().used == true
        && incoming().userId == request.auth.uid
        && incoming().token == existing().token
        && incoming().email == existing().email;
      allow delete: if false;
    }

    match /business_profiles/{userId} {
      allow get: if true;
      allow list: if false;
      allow create: if isOwner(userId) && isValidBusinessProfile(incoming());
      allow update: if isOwner(userId) && isValidBusinessProfile(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }

    match /business_services/{serviceId} {
      allow get: if true;
      allow list: if true; // Public listings allowed for bookings
      allow create: if isSignedIn() && isValidId(serviceId) && isValidBusinessService(incoming()) && isOwner(incoming().userId);
      allow update: if isSignedIn() && isValidId(serviceId) && existing().userId == request.auth.uid && isValidBusinessService(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /business_bookings/{bookingId} {
      allow get: if true; // Clients and owners can view status with ID
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.clientEmail == request.auth.token.email);
      allow create: if isValidId(bookingId) && isValidBusinessBooking(incoming());
      allow update: if (isValidId(bookingId) && isSignedIn() && existing().userId == request.auth.uid && isValidBusinessBooking(incoming()) && incoming().userId == existing().userId)
        || (isValidId(bookingId) && existing().clientEmail == request.auth.token.email && isValidBusinessBooking(incoming()) && incoming().status == 'cancelled' && incoming().userId == existing().userId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
