rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default to deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validator definitions
    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 200
        && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 150))
        && (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 1000));
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.amount is number && data.amount >= 0 && data.amount <= 100000000
        && (data.type == 'fixos' || data.type == 'variaveis' || data.type == 'parcelas')
        && data.cat is string && data.cat.size() <= 50
        && data.monthKey is string && data.monthKey.size() == 7
        && data.paid_amount is number && data.paid_amount >= 0
        && (!data.keys().hasAny(['due']) || (data.due is string && data.due.size() <= 50))
        && (!data.keys().hasAny(['paid_at']) || (data.paid_at is string && data.paid_at.size() <= 50))
        && (!data.keys().hasAny(['masterId']) || (data.masterId is string && data.masterId.size() <= 128));
    }

    function isValidCategory(data) {
      return data.userId == request.auth.uid
        && data.id is string && data.id.size() <= 128
        && data.icon is string && data.icon.size() <= 20
        && data.label is string && data.label.size() <= 100
        && data.value is string && data.value.size() <= 100;
    }

    function isValidGoal(data) {
      return data.userId == request.auth.uid
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 150
        && data.targetAmount is number && data.targetAmount >= 0
        && data.currentAmount is number && data.currentAmount >= 0
        && (!data.keys().hasAny(['deadline']) || (data.deadline is string && data.deadline.size() <= 50))
        && (!data.keys().hasAny(['createdAt']) || (data.createdAt is string && data.createdAt.size() <= 50));
    }

    function isValidSetting(data) {
      return data.userId == request.auth.uid
        && data.currency is string && (data.currency == 'BRL' || data.currency == 'USD' || data.currency == 'EUR')
        && data.theme is string && (data.theme == 'dark' || data.theme == 'light')
        && data.income is number && data.income >= 0
        && data.balance is number && data.balance >= 0
        && (!data.keys().hasAny(['extras']) || data.extras is map);
    }

    function isValidNotification(data) {
      return data.userId == request.auth.uid
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.body is string && data.body.size() <= 1000
        && data.read is bool;
    }

    // Rules for Collections
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == existing().uid;
      allow delete: if isOwner(userId);
    }

    match /transactions/{transactionId} {
      allow get, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(transactionId) && isValidTransaction(incoming());
      allow update: if isSignedIn() && isValidId(transactionId) && existing().userId == request.auth.uid && isValidTransaction(incoming()) && incoming().userId == existing().userId;
    }

    match /categories/{categoryId} {
      allow get, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isSignedIn() && isValidId(categoryId) && existing().userId == request.auth.uid && isValidCategory(incoming()) && incoming().userId == existing().userId;
    }

    match /goals/{goalId} {
      allow get, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(goalId) && isValidGoal(incoming());
      allow update: if isSignedIn() && isValidId(goalId) && existing().userId == request.auth.uid && isValidGoal(incoming()) && incoming().userId == existing().userId;
    }

    match /settings/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSetting(incoming());
      allow update: if isOwner(userId) && isValidSetting(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }

    match /notifications/{notificationId} {
      allow get, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming());
      allow update: if isSignedIn() && isValidId(notificationId) && existing().userId == request.auth.uid && isValidNotification(incoming()) && incoming().userId == existing().userId;
    }

    match /push_subscriptions/{subId} {
      allow get, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(subId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(subId) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
    }
  }
}
